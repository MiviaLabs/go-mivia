#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"
case "$cmd" in
  --version|-v|version)
    echo "mivia-graphify-wrapper 0.1.0"
    exit 0
    ;;
  update)
    target="${2:-.}"
    mkdir -p "$target/graphify-out"
    python3 - "$target" <<'PY'
import hashlib
import json
import os
import sys
from datetime import datetime, timezone

root = os.path.abspath(sys.argv[1])
out_dir = os.path.join(root, "graphify-out")
manifest = {}
for base, dirs, files in os.walk(root):
    dirs[:] = [
        d for d in dirs
        if d not in {".git", "node_modules", ".dart_tool", "build", ".mivia-worktrees", ".claude"}
        and not (base == root and d == "graphify-out")
    ]
    for name in files:
        path = os.path.join(base, name)
        rel = os.path.relpath(path, root)
        try:
            with open(path, "rb") as f:
                data = f.read()
        except OSError:
            continue
        manifest[rel] = {
            "sha256": hashlib.sha256(data).hexdigest(),
            "bytes": len(data),
        }

payload = {
    "generated_at": datetime.now(timezone.utc).isoformat(),
    "root": root,
    "files": manifest,
}
with open(os.path.join(out_dir, "manifest.json"), "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, sort_keys=True)
    f.write("\n")
with open(os.path.join(out_dir, "graph.json"), "w", encoding="utf-8") as f:
    json.dump({"nodes": [{"id": k, "label": k, "bytes": v["bytes"]} for k, v in manifest.items()], "edges": []}, f, indent=2, sort_keys=True)
    f.write("\n")
with open(os.path.join(out_dir, "GRAPH_REPORT.md"), "w", encoding="utf-8") as f:
    f.write("# Graphify Report\n\n")
    f.write(f"Generated: {payload['generated_at']}\n\n")
    f.write(f"Files indexed: {len(manifest)}\n")
PY
    echo "graphify update completed: $target/graphify-out"
    ;;
  query|path|explain)
    target="."
    if [ -f "$target/graphify-out/GRAPH_REPORT.md" ]; then
      sed -n '1,80p' "$target/graphify-out/GRAPH_REPORT.md"
    else
      echo "graphify: no graphify-out found; run 'graphify update .' first" >&2
      exit 1
    fi
    ;;
  *)
    echo "usage: graphify {update <path>|query <text>|path <text>|explain <text>|--version}" >&2
    exit 2
    ;;
esac
